#!/usr/bin/env bash
# Entry point for cag-search.
# Prefers the native OCaml binary if built; falls back to the Python prototype.
set -euo pipefail
HERE="$(cd "$(dirname "$0")" && pwd)"
TOOLS_ROOT="$(dirname "$HERE")"
PROJECT_ROOT="$(dirname "$TOOLS_ROOT")"

OCAML_BIN="$PROJECT_ROOT/_build/default/tools/ocaml/cag_search/cag_search.exe"
if [ -x "$OCAML_BIN" ]; then
  exec "$OCAML_BIN" "$@"
fi

# Fallback: Python prototype.
exec env PYTHONPATH="$TOOLS_ROOT" python3 -m cag_search.cli "$@"
