#!/usr/bin/env bash
# cag-hammer: try CoqHammer / sauto on an isolated goal.
#
# Usage:
#   cag-hammer 'forall x, P x -> Q x'             # attempts hammer on the goal
#   cag-hammer --tactic sauto 'forall x, P x'     # try a specific tactic
#   cag-hammer --import 'CAG.Group' 'forall ...'  # import a module first
#   cag-hammer --timeout 30 ...                   # ATP timeout (default 20s)
#
# Writes a self-contained .v file under .cag/, runs `rocq compile`, and
# reports success / failure. Does NOT modify any source file.
set -euo pipefail
HERE="$(cd "$(dirname "$0")" && pwd)"
TOOLS_ROOT="$(dirname "$HERE")"
PROJECT_ROOT="$(dirname "$TOOLS_ROOT")"

TACTIC="hammer"
TIMEOUT=20
IMPORTS=()
GOAL=""

while (( "$#" )); do
  case "$1" in
    --tactic)  TACTIC="$2"; shift 2 ;;
    --timeout) TIMEOUT="$2"; shift 2 ;;
    --import)  IMPORTS+=("$2"); shift 2 ;;
    -h|--help) sed -n '2,12p' "$0"; exit 0 ;;
    *)         GOAL="$1"; shift ;;
  esac
done

if [ -z "$GOAL" ]; then
  echo "usage: cag-hammer [--tactic T] [--timeout S] [--import MOD]... GOAL" >&2
  exit 2
fi

mkdir -p "$PROJECT_ROOT/.cag"
OUT="$PROJECT_ROOT/.cag/_hammer_probe.v"
{
  echo "From Hammer Require Import Hammer Tactics."
  for m in "${IMPORTS[@]}"; do echo "Require Import $m."; done
  echo "Set Hammer ATPLimit $TIMEOUT."
  echo "Goal $GOAL."
  echo "Proof. $TACTIC. Qed."
} > "$OUT"

cd "$PROJECT_ROOT"
eval "$(opam env --switch=rocq-9.0 --set-switch)" >/dev/null 2>&1 || true
START=$(date +%s)
if rocq compile -Q theories CAG "$OUT" 2>&1; then
  END=$(date +%s)
  echo "✓ closed by '$TACTIC' in $((END-START))s"
  exit 0
else
  echo "✗ failed under '$TACTIC' (timeout=${TIMEOUT}s)" >&2
  exit 1
fi
